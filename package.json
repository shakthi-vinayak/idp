{
  "name": "enterprise-idp",
  "private": true,
  "version": "1.2.0",
  "description": "NexusIDP — Enterprise-grade Internal Developer Platform with self-service infrastructure, GitOps pipelines, and unified developer experience",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node api/server.js",
    "dev:all": "npx concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "platform-engineering",
    "internal-developer-platform",
    "idp",
    "kubernetes",
    "devops",
    "gitops",
    "react",
    "typescript",
    "developer-experience",
    "self-service"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shakthi-vinayak/idp.git"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  }
}
